# SiliconPulse Backend Configuration

# App Settings
APP_NAME="SiliconPulse"
DEBUG=True

# Data Stream
DATA_STREAM_PATH="data/stream.jsonl"
MAX_EVENTS_TO_SCAN=500
FRESHNESS_HOURS=12

# Database (SQLite)
DB_PATH="data/siliconpulse.db"
DEDUP_ENABLED=True
CHECKPOINT_ENABLED=True

# Gemini AI (Required for Insights)
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-2.0-flash-exp"
GEMINI_FALLBACK_MODELS=["gemini-1.5-flash", "gemini-1.5-pro"]

# Clerk Auth (Required for protected API routes)
CLERK_ISSUER="https://your-domain.clerk.accounts.dev"
CLERK_AUDIENCE=""

# Supabase (Optional but required for persistence)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# Pathway Settings
USE_PATHWAY=True
PATHWAY_OUTPUT_PATH="data/pathway_out.jsonl"

# GDELT Configuration (free API - no key required)
GDELT_ENABLED=True

# HackerNews Configuration (free Algolia API - no key required)
HACKERNEWS_ENABLED=True

# External news providers (free APIs)
NEWSAPI_API_KEY="your_newsapi_api_key_here"
